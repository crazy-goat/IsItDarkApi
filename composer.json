{
  "name": "crazy-goat/isitdarkapi",
  "type": "project",
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/crazy-goat/IsItDark"
    }
  ],
  "keywords": ["astronomy", "sunrise", "sunset", "dark", "api"],
  "homepage": "https://github.com/crazy-goat/IsItDarkApi",
  "license": "MIT",
  "description": "REST API to determine if it is currently dark at any geographic location.",
  "authors": [
    {
      "name": "Piotr Halas",
      "role": "Developer"
    }
  ],
  "support": {
    "issues": "https://github.com/crazy-goat/IsItDarkApi/issues",
    "source": "https://github.com/crazy-goat/IsItDarkApi"
  },
    "require": {
    "php": ">=8.4",
    "workerman/webman-framework": "^2.1",
    "monolog/monolog": "^2.0",
    "crazy-goat/is-it-dark": "dev-main",
    "open-telemetry/sdk": "^1.1",
    "open-telemetry/exporter-otlp": "^1.1",
    "nyholm/psr7": "^1.8",
    "guzzlehttp/guzzle": "^7.10"
  },
  "suggest": {
    "ext-event": "For better performance. "
  },
  "autoload": {
    "psr-4": {
      "": "./",
      "app\\": "./app",
      "app\\View\\Components\\": "./app/view/components"
    }
  },
  "scripts": {
    "post-package-install": [
      "support\\Plugin::install"
    ],
    "post-package-update": [
      "support\\Plugin::install"
    ],
    "pre-package-uninstall": [
      "support\\Plugin::uninstall"
    ],
    "post-create-project-cmd": [
      "support\\Setup::run"
    ],
    "setup-webman": [
      "support\\Setup::run"
    ],
    "test": [
      "phpunit"
    ],
    "test-unit": [
      "phpunit --testsuite Unit"
    ],
    "test-feature": [
      "phpunit --testsuite Feature"
    ],
    "test-coverage": [
      "phpunit --coverage-html coverage-html"
    ],
    "lint": [
      "./vendor/bin/rector process --dry-run",
      "./vendor/bin/phpcs --standard=phpcs.xml.dist",
      "./vendor/bin/phpstan analyse"
    ],
    "lint:fix": [
      "./vendor/bin/rector process",
      "./vendor/bin/phpcbf --standard=phpcs.xml.dist"
    ],
    "phpstan": [
      "./vendor/bin/phpstan analyse"
    ]
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require-dev": {
    "phpunit/phpunit": "^13.0",
    "squizlabs/php_codesniffer": "^3.10",
    "slevomat/coding-standard": "^8.15",
    "phpstan/phpstan": "^2.0",
    "rector/rector": "^2.0"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
